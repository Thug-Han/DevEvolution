<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Android模块"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_leak_canary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LeakCanary内存泄漏检测"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_handler_thread"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="HandlerThread异步下载"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_crash"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crash崩溃捕获"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_anr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ANR示例" />

</LinearLayout>
