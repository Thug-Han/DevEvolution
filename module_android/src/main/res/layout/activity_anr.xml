<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ANR (Application Not Responding) 示例"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activity ANR: 主线程阻塞5秒\n前台Service ANR: 主线程阻塞20秒\n后台Service ANR: 主线程阻塞200秒，进程直接被杀"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_activity_anr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="触发Activity ANR"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_foreground_service_anr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="触发前台Service ANR"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_background_service_anr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="触发后台Service ANR" />

</LinearLayout>
