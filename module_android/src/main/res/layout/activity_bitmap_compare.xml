<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bitmap内存演示"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F44336"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_run_bad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行问题代码"
                android:textSize="12sp"
                android:backgroundTint="#F44336"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_run_good"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行优化代码"
                android:textSize="12sp"
                android:backgroundTint="#4CAF50"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="重置"
                android:textSize="12sp"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_back"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="返回"
                android:textSize="12sp"
                android:backgroundTint="#9E9E9E"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_problem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="问题代码"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#FFEBEE"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_detect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="检测方法"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_fix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="修复方法"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#E8F5E9"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <ImageView
            android:id="@+id/iv_demo"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerInside"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_optimize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="优化后正常代码"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#FFF8E1"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <ImageView
            android:id="@+id/iv_demo_optimized"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerInside"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="对比结果"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>
</ScrollView>
